<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>POS KASIR PINTAR - Solusi Transaksi Toko Modern</title>
  
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Chart.js CDN untuk Laporan Finansial -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  
  <style>
    /* Mengambil alih seluruh halaman Blogger (Blogger Full-Page Takeover) */
    .blogger-full-page {
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      width: 100vw !important;
      height: 100vh !important;
      z-index: 99999999 !important;
      background-color: #f8fafc;
      overflow: hidden;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    
    /* Scrollbar Styling */
    ::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    ::-webkit-scrollbar-track {
      background: #f1f5f9;
    }
    ::-webkit-scrollbar-thumb {
      background: #cbd5e1;
      border-radius: 3px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: #94a3b8;
    }

    /* Print styling khusus untuk Struk Kasir Thermal (58mm) */
    @media print {
      body * {
        visibility: hidden;
      }
      #print-receipt-modal, #print-receipt-modal * {
        visibility: visible;
      }
      #print-receipt-modal {
        position: absolute;
        left: 0;
        top: 0;
        width: 58mm;
        margin: 0;
        padding: 0;
        background: white;
        color: black;
        font-size: 10px;
      }
      .no-print {
        display: none !important;
      }
    }
  </style>
</head>
<body>

<div class="blogger-full-page flex flex-col h-screen text-slate-800" id="app-root">
  
  <!-- ==================== AREA LOGIN ==================== -->
  <div id="login-container" class="flex items-center justify-center h-full w-full bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900 px-4">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-2xl p-8 border border-slate-100 transition-all duration-300 transform hover:scale-105">
      <div class="text-center mb-8">
        <div class="inline-flex p-3 bg-indigo-50 text-indigo-600 rounded-2xl mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-slate-800" id="login-title">POS Kasir Pintar</h2>
        <p class="text-sm text-slate-500 mt-1">Silakan masuk dengan akun Anda untuk mulai bertransaksi</p>
      </div>

      <div id="login-alert" class="hidden mb-4 p-3 bg-rose-50 text-rose-700 text-sm rounded-lg border border-rose-100"></div>

      <form id="login-form" onsubmit="handleLogin(event)">
        <div class="space-y-4">
          <div>
            <label class="block text-xs font-semibold uppercase text-slate-500 mb-1">Username</label>
            <input type="text" id="username" required class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none text-slate-800" placeholder="Masukkan username">
          </div>
          <div>
            <label class="block text-xs font-semibold uppercase text-slate-500 mb-1">Password</label>
            <input type="password" id="password" required class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none text-slate-800" placeholder="••••••••">
          </div>
          
          <div class="flex items-center justify-between py-1">
            <label class="flex items-center space-x-2 text-sm text-slate-600 cursor-pointer">
              <input type="checkbox" id="chk-preview-mode" onchange="togglePreviewModeCheckbox(this)" class="rounded text-indigo-600 focus:ring-indigo-500 border-slate-300 h-4 w-4">
              <span>Aktifkan Mode Preview</span>
            </label>
            <span id="preview-badge" class="hidden bg-emerald-100 text-emerald-800 text-xs px-2.5 py-0.5 rounded-full font-medium">Bypass On</span>
          </div>

          <div id="preview-pass-field" class="hidden">
            <label class="block text-xs font-semibold uppercase text-emerald-600 mb-1">Password Bypass Preview</label>
            <input type="password" id="preview-password" class="w-full px-4 py-2 border border-emerald-200 bg-emerald-50/30 rounded-xl focus:ring-2 focus:ring-emerald-500 focus:outline-none text-slate-800" placeholder="Ketik: visualsukses">
          </div>

          <button type="submit" id="btn-login" class="w-full py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl shadow-lg shadow-indigo-100 transition duration-150 flex justify-center items-center">
            <span>Masuk Aplikasi</span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- ==================== AREA UTAMA APLIKASI (DISEMBUNYIKAN SEBELUM LOGIN) ==================== -->
  <div id="main-app-container" class="hidden flex flex-row h-full w-full overflow-hidden">
    
    <!-- SIDEBAR NAVIGASI -->
    <aside class="w-64 bg-slate-900 text-slate-400 flex flex-col justify-between shrink-0">
      <div>
        <!-- Profil Singkat Toko di Atas -->
        <div class="p-6 border-b border-slate-800 flex items-center space-x-3">
          <div class="p-2 bg-indigo-600 text-white rounded-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <div>
            <h1 class="font-bold text-white tracking-wide" id="sidebar-shop-name">TOKO KITA</h1>
            <span class="text-xs text-emerald-400 font-medium flex items-center" id="session-role">
              <span class="w-2 h-2 rounded-full bg-emerald-400 mr-1.5 animate-pulse"></span>
              Admin
            </span>
          </div>
        </div>

        <!-- Menu List -->
        <nav class="p-4 space-y-1">
          <!-- POS / Transaksi -->
          <button onclick="switchView('pos')" id="menu-pos" class="w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition text-left group">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2zM10 8.5a.5.5 0 11-1 0 .5.5 0 011 0zm4.5 5a.5.5 0 11-1 0 .5.5 0 011 0z" />
            </svg>
            <span class="font-medium text-sm">POS Kasir</span>
          </button>

          <!-- Manajemen Produk (Khusus Admin) -->
          <button onclick="switchView('products')" id="menu-products" class="admin-only w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition text-left group">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            <span class="font-medium text-sm">Kelola Produk</span>
          </button>

          <!-- Riwayat Transaksi -->
          <button onclick="switchView('history')" id="menu-history" class="w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition text-left group">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="font-medium text-sm">Riwayat Transaksi</span>
          </button>

          <!-- Laporan Keuangan (Khusus Admin) -->
          <button onclick="switchView('reports')" id="menu-reports" class="admin-only w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition text-left group">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            <span class="font-medium text-sm">Laporan Grafik</span>
          </button>

          <!-- Manajemen Pengguna / Kasir (Khusus Admin) -->
          <button onclick="switchView('users')" id="menu-users" class="admin-only w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition text-left group">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <span class="font-medium text-sm">Kelola Kasir</span>
          </button>

          <!-- Pengaturan Toko (Khusus Admin) -->
          <button onclick="switchView('settings')" id="menu-settings" class="admin-only w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition text-left group">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="font-medium text-sm">Pengaturan</span>
          </button>
        </nav>
      </div>

      <!-- Informasi Pengguna & Logout di Bawah -->
      <div class="p-4 border-t border-slate-800 space-y-2">
        <div class="flex items-center space-x-3 px-2 py-1.5">
          <div class="w-9 h-9 rounded-full bg-slate-700 flex items-center justify-center text-white font-bold text-sm tracking-wide shadow" id="avatar-fallback">
            KS
          </div>
          <div class="overflow-hidden">
            <h4 class="text-sm font-semibold text-white truncate" id="session-username">Nama Kasir</h4>
            <span class="text-xs text-slate-500 truncate block" id="session-role-label">Kasir Toko</span>
          </div>
        </div>
        <button onclick="handleLogout()" class="w-full flex items-center justify-center space-x-2 py-2 bg-slate-800 hover:bg-rose-950 hover:text-rose-400 text-slate-400 rounded-xl transition text-sm font-semibold mt-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
          <span>Keluar</span>
        </button>
      </div>
    </aside>

    <!-- KONTEN UTAMA DENGAN HEADER SISTEM -->
    <main class="flex-1 flex flex-col min-w-0 bg-slate-50">
      
      <!-- HEADER ATAS -->
      <header class="h-16 bg-white border-b border-slate-100 flex items-center justify-between px-6 shrink-0 shadow-sm z-10">
        <div class="flex items-center space-x-3">
          <h2 class="text-lg font-bold text-slate-800" id="current-view-title">POS Kasir</h2>
          <span id="badge-offline" class="hidden bg-amber-100 text-amber-800 text-xs px-2.5 py-0.5 rounded-full font-medium flex items-center">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500 mr-1 animate-pulse"></span>
            Mode Preview Aktif
          </span>
        </div>
        
        <!-- Indikator Konektivitas / Tanggal Real-time -->
        <div class="flex items-center space-x-4 text-sm text-slate-500">
          <span id="live-clock" class="font-mono bg-slate-100 px-3 py-1 rounded-lg text-slate-600">00:00:00 - 09 Juni 2026</span>
          <div class="h-4 w-px bg-slate-200"></div>
          <div class="flex items-center space-x-2">
            <span class="w-2.5 h-2.5 rounded-full bg-emerald-500" id="conn-indicator"></span>
            <span id="conn-text" class="text-xs font-semibold text-slate-600">Terhubung</span>
          </div>
        </div>
      </header>

      <!-- PANUTAN KONTEN YANG BISA DI-SCROLL -->
      <div class="flex-1 overflow-y-auto p-6" id="content-area">
        
        <!-- ==================== VIEW 1: POS / KASIR ==================== -->
        <div id="view-pos" class="hidden h-full flex flex-col md:flex-row gap-6">
          
          <!-- Sisi Kiri: Daftar Produk & Pencarian -->
          <div class="flex-1 flex flex-col bg-white rounded-2xl shadow-sm border border-slate-100 p-5 min-w-0 overflow-hidden">
            <!-- Filter & Bar Pencarian -->
            <div class="flex flex-col sm:flex-row gap-3 mb-4 shrink-0">
              <div class="relative flex-1">
                <input type="text" id="pos-search" oninput="filterPOSProducts()" class="w-full pl-10 pr-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="Ketik nama produk atau scan barcode...">
                <div class="absolute left-3.5 top-3 text-slate-400">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                  </svg>
                </div>
              </div>
              <select id="pos-category-filter" onchange="filterPOSProducts()" class="px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white">
                <option value="">Semua Kategori</option>
              </select>
            </div>

            <!-- Grid Produk (Di-scroll secara internal) -->
            <div class="flex-1 overflow-y-auto">
              <div id="pos-products-grid" class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-4 gap-4 pr-1">
                <!-- Produk di-render dinamis -->
              </div>
              <!-- State Jika Produk Kosong -->
              <div id="pos-empty-state" class="hidden flex flex-col items-center justify-center py-16 text-slate-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-slate-300 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
                <p class="text-sm">Produk tidak ditemukan</p>
              </div>
            </div>
          </div>

          <!-- Sisi Kanan: Panel Keranjang Belanja -->
          <div class="w-full md:w-[380px] xl:w-[420px] shrink-0 bg-white rounded-2xl shadow-sm border border-slate-100 flex flex-col overflow-hidden max-h-full">
            <div class="p-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
              <span class="font-bold text-slate-800 flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1.5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
                Detail Keranjang
              </span>
              <button onclick="clearCart()" class="text-xs text-rose-600 hover:text-rose-800 font-semibold px-2 py-1 hover:bg-rose-50 rounded-lg transition">Kosongkan</button>
            </div>

            <!-- List Cart (Scrollable) -->
            <div class="flex-1 overflow-y-auto p-4 space-y-3" id="cart-items-list">
              <!-- Item keranjang di-render dinamis -->
            </div>

            <!-- Area Summary & Pembayaran (Tetap di bawah) -->
            <div class="border-t border-slate-100 p-4 bg-slate-50/30 space-y-3">
              <div class="flex justify-between text-sm text-slate-600">
                <span>Subtotal</span>
                <span id="cart-subtotal" class="font-mono font-semibold">Rp 0</span>
              </div>
              <div class="flex items-center justify-between text-sm text-slate-600">
                <span>Diskon Toko (Rp)</span>
                <input type="number" id="cart-discount" oninput="calculateCartTotal()" min="0" class="w-28 text-right px-2.5 py-1 border border-slate-200 rounded-lg font-mono focus:outline-none focus:ring-1 focus:ring-indigo-500" value="0">
              </div>
              <div class="flex justify-between items-center pt-2 border-t border-dashed border-slate-200">
                <span class="font-bold text-slate-800">TOTAL AKHIR</span>
                <span id="cart-grand-total" class="text-xl font-bold font-mono text-indigo-600">Rp 0</span>
              </div>

              <!-- Form Input Nominal Bayar -->
              <div class="pt-2 space-y-1.5">
                <label class="block text-xs font-semibold uppercase text-slate-500">Nominal Uang Tunai (Rp)</label>
                <div class="relative">
                  <input type="number" id="cash-payment" oninput="calculateChange()" class="w-full text-right pr-4 pl-12 py-2.5 border border-slate-200 rounded-xl font-mono text-lg font-bold focus:outline-none focus:ring-2 focus:ring-indigo-500 text-slate-800" placeholder="0">
                  <div class="absolute left-3.5 top-3 text-slate-400 font-bold text-sm">Rp</div>
                </div>
              </div>

              <!-- Pilihan Cepat Nominal Uang Pas -->
              <div class="grid grid-cols-3 gap-1.5 text-center">
                <button onclick="setCashFast(20000)" class="py-1 bg-slate-100 hover:bg-slate-200 text-xs font-semibold rounded-lg font-mono text-slate-700">20k</button>
                <button onclick="setCashFast(50000)" class="py-1 bg-slate-100 hover:bg-slate-200 text-xs font-semibold rounded-lg font-mono text-slate-700">50k</button>
                <button onclick="setCashFast(100000)" class="py-1 bg-slate-100 hover:bg-slate-200 text-xs font-semibold rounded-lg font-mono text-slate-700">100k</button>
              </div>

              <div class="flex justify-between text-sm py-1">
                <span class="text-slate-500">Kembalian</span>
                <span id="cash-change" class="font-mono font-bold text-emerald-600">Rp 0</span>
              </div>

              <!-- Tombol Checkout -->
              <button onclick="processCheckout()" class="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition flex justify-center items-center space-x-2 shadow-lg shadow-indigo-100">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
                <span>Bayar & Cetak Struk</span>
              </button>
            </div>
          </div>

        </div>

        <!-- ==================== VIEW 2: KELOLA PRODUK (CRUD) ==================== -->
        <div id="view-products" class="hidden space-y-6">
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-slate-100">
            <div class="flex flex-wrap gap-2 w-full sm:w-auto">
              <input type="text" id="product-search" oninput="renderProductTable()" class="px-4 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 w-full sm:w-64" placeholder="Cari nama produk / barcode...">
              <select id="product-stock-filter" onchange="renderProductTable()" class="px-4 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white">
                <option value="all">Semua Stok</option>
                <option value="low">Stok Menipis (<= 5)</option>
              </select>
            </div>
            <button onclick="openProductModal()" class="w-full sm:w-auto px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl text-sm shadow-md transition flex items-center justify-center space-x-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
              <span>Tambah Produk Baru</span>
            </button>
          </div>

          <!-- Tabel Produk -->
          <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="overflow-x-auto">
