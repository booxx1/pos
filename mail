  function filterPOSProducts() {
    const keyword = document.getElementById('pos-search').value.toLowerCase();
    const cat = document.getElementById('pos-category-filter').value;
    const grid = document.getElementById('pos-products-grid');
    const empty = document.getElementById('pos-empty-state');

    grid.innerHTML = '';
    
    // Cari produk yang sesuai
    const filtered = db_products.filter(p => {
      const matchKeyword = p.nama_produk.toLowerCase().includes(keyword) || p.barcode.includes(keyword);
      const matchCategory = cat === "" || p.kategori === cat;
      return matchKeyword && matchCategory;
    });

    if (filtered.length === 0) {
      empty.classList.remove('hidden');
    } else {
      empty.classList.add('hidden');
      filtered.forEach(p => {
        const isLow = p.stok <= 5;
        const stockBadgeClass = isLow ? 'bg-rose-100 text-rose-800' : 'bg-slate-100 text-slate-800';
        
        grid.innerHTML += `
          <div onclick="addToCart('${p.id_produk}')" class="bg-white rounded-xl border border-slate-200/80 p-3.5 hover:shadow-md hover:border-indigo-400 cursor-pointer transition flex flex-col justify-between h-36">
            <div>
              <div class="flex justify-between items-start gap-1">
                <span class="text-xs text-slate-400 font-semibold truncate tracking-wider">${p.kategori}</span>
                <span class="text-[10px] px-2 py-0.5 rounded font-bold ${stockBadgeClass}">Stok: ${p.stok}</span>
              </div>
              <h4 class="font-bold text-slate-800 text-sm mt-1.5 leading-snug line-clamp-2">${p.nama_produk}</h4>
            </div>
            <div class="flex justify-between items-end mt-2">
              <span class="text-xs font-mono text-slate-400">${p.barcode}</span>
              <span class="font-black text-sm text-indigo-600 font-mono">${formatIDR(p.harga_jual)}</span>
            </div>
          </div>
        `;
      });
    }
  }

  function addToCart(productId) {
    const prod = db_products.find(p => p.id_produk === productId);
    if (!prod) return;

    if (prod.stok <= 0) {
      showToast("Gagal! Stok produk habis.", "error");
      return;
    }

    const existing = cart.find(item => item.id_produk === productId);
    if (existing) {
      if (existing.qty >= prod.stok) {
        showToast("Gagal! Melebihi sisa stok yang tersedia.", "error");
        return;
      }
      existing.qty++;
    } else {
      cart.push({
        id_produk: prod.id_produk,
        nama_produk: prod.nama_produk,
        harga_beli: prod.harga_beli,
        harga_jual: prod.harga_jual,
        qty: 1
      });
    }

    renderCart();
  }

  function updateCartQty(index, qty) {
    const item = cart[index];
    const prod = db_products.find(p => p.id_produk === item.id_produk);
    
    qty = parseInt(qty);
    if (isNaN(qty) || qty <= 0) {
      cart.splice(index, 1);
    } else {
      if (qty > prod.stok) {
        showToast("Stok tidak mencukupi untuk " + item.nama_produk, "error");
        return;
      }
      item.qty = qty;
    }
    renderCart();
  }

  function removeFromCart(index) {
    cart.splice(index, 1);
    renderCart();
  }

  function clearCart() {
    cart = [];
    document.getElementById('cart-discount').value = 0;
    document.getElementById('cash-payment').value = '';
    renderCart();
  }

  function renderCart() {
    const container = document.getElementById('cart-items-list');
    container.innerHTML = '';

    if (cart.length === 0) {
      container.innerHTML = `
        <div class="flex flex-col items-center justify-center py-12 text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-slate-300 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          <p class="text-xs text-center font-medium">Keranjang belanja kosong</p>
        </div>
      `;
      calculateCartTotal();
      return;
    }

    cart.forEach((item, index) => {
      container.innerHTML += `
        <div class="flex items-center justify-between border-b border-slate-100 pb-3 gap-2">
          <div class="min-w-0 flex-1">
            <h5 class="font-bold text-slate-800 text-xs truncate leading-snug">${item.nama_produk}</h5>
            <span class="text-xs text-slate-400 font-mono">${formatIDR(item.harga_jual)}</span>
          </div>
          <div class="flex items-center space-x-2 shrink-0">
            <div class="flex items-center border border-slate-200 rounded-lg overflow-hidden bg-white">
              <button onclick="updateCartQty(${index}, ${item.qty - 1})" class="px-2.5 py-1 text-slate-500 hover:bg-slate-100 font-bold text-xs">-</button>
              <input type="number" onchange="updateCartQty(${index}, this.value)" class="w-10 text-center text-xs font-bold font-mono focus:outline-none" value="${item.qty}">
              <button onclick="updateCartQty(${index}, ${item.qty + 1})" class="px-2.5 py-1 text-slate-500 hover:bg-slate-100 font-bold text-xs">+</button>
            </div>
            <button onclick="removeFromCart(${index})" class="text-slate-300 hover:text-rose-600 transition">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            </button>
          </div>
        </div>
      `;
    });

    calculateCartTotal();
  }

  function calculateCartTotal() {
    let subtotal = cart.reduce((acc, item) => acc + (item.harga_jual * item.qty), 0);
    let discount = parseInt(document.getElementById('cart-discount').value) || 0;
    
    if (discount < 0) discount = 0;
    let grandTotal = subtotal - discount;
    if (grandTotal < 0) grandTotal = 0;

    document.getElementById('cart-subtotal').innerText = formatIDR(subtotal);
    document.getElementById('cart-grand-total').innerText = formatIDR(grandTotal);

    calculateChange();
  }

  function calculateChange() {
    let grandTotalText = document.getElementById('cart-grand-total').innerText;
    let grandTotal = parseInt(grandTotalText.replace(/[^0-9]/g, '')) || 0;
    let cash = parseInt(document.getElementById('cash-payment').value) || 0;
    let change = cash - grandTotal;

    if (change < 0 || cash === 0) {
      document.getElementById('cash-change').innerText = formatIDR(0);
      document.getElementById('cash-change').className = "font-mono font-bold text-slate-400";
    } else {
      document.getElementById('cash-change').innerText = formatIDR(change);
      document.getElementById('cash-change').className = "font-mono font-bold text-emerald-600";
    }
  }

  function setCashFast(amount) {
    document.getElementById('cash-payment').value = amount;
    calculateChange();
  }

  function processCheckout() {
    if (cart.length === 0) {
      showToast("Keranjang Anda masih kosong!", "error");
      return;
    }

    let grandTotalText = document.getElementById('cart-grand-total').innerText;
    let grandTotal = parseInt(grandTotalText.replace(/[^0-9]/g, '')) || 0;
    let cash = parseInt(document.getElementById('cash-payment').value) || 0;
    let discount = parseInt(document.getElementById('cart-discount').value) || 0;
    let subtotal = cart.reduce((acc, item) => acc + (item.harga_jual * item.qty), 0);

    if (cash < grandTotal) {
      showToast("Uang tunai pembayaran tidak mencukupi!", "error");
      return;
    }

    // Persiapan Object Transaksi
    const now = new Date();
    const invoiceNum = "INV-" + now.getFullYear().toString().slice(-2) + 
                       (now.getMonth()+1).toString().padStart(2,'0') + 
                       now.getDate().toString().padStart(2,'0') + "-" + 
                       Math.floor(1000 + Math.random() * 9000);

    const invoiceDate = now.toISOString().split('T')[0];
    const invoiceTime = now.toTimeString().split(' ')[0].substring(0,5);

    const transactionData = {
      id_transaksi: "T" + (db_transactions.length + 1001),
      no_invoice: invoiceNum,
      tanggal: invoiceDate,
      waktu: invoiceTime,
      id_user: currentUser.id_user,
      total_beli: cart.reduce((acc, item) => acc + (item.harga_beli * item.qty), 0),
      total_jual: subtotal,
      diskon: discount,
      total_akhir: grandTotal,
      bayar: cash,
      kembali: cash - grandTotal
    };

    const detailsData = cart.map((item, idx) => ({
      id_detail: "D" + (db_transaction_details.length + 1001 + idx),
      no_invoice: invoiceNum,
      id_produk: item.id_produk,
      nama_produk: item.nama_produk,
      qty: item.qty,
      harga_beli_saat_ini: item.harga_beli,
      harga_jual_saat_ini: item.harga_jual,
      subtotal: item.harga_jual * item.qty
    }));

    if (IS_PREVIEW) {
      // PROSES SIMULASI LOKAL
      // 1. Kurangi stok produk lokal
      cart.forEach(item => {
        const prod = db_products.find(p => p.id_produk === item.id_produk);
        if (prod) prod.stok -= item.qty;
      });

      // 2. Simpan Transaksi & Detail
      db_transactions.push(transactionData);
      detailsData.forEach(d => db_transaction_details.push(d));

      showToast("Transaksi Berhasil Diproses (Preview Mode)!");
      showReceipt(transactionData, detailsData);
      clearCart();
      fetchAppData();
    } else {
      // PROSES NYATA CLOUD GAS
      showToast("Mengirim transaksi ke database cloud...", "success");
      google.script.run
        .withSuccessHandler((res) => {
          if (res.success) {
            showToast("Transaksi Berhasil Tersimpan!");
            showReceipt(transactionData, detailsData);
            clearCart();
            fetchAppData();
          } else {
            showToast("Gagal memproses transaksi: " + res.message, "error");
          }
        })
        .withFailureHandler((err) => {
          showToast("Error sistem: " + err.message, "error");
        })
        .processTransaction(transactionData, detailsData);
    }
  }

  /******************************************************************
   * STRUK THERMAL LAYOUT & CETAK
   ******************************************************************/
  function showReceipt(tx, details) {
    document.getElementById('rec-invoice').innerText = tx.no_invoice;
    document.getElementById('rec-date').innerText = tx.tanggal;
    document.getElementById('rec-time').innerText = tx.waktu;
    
    // Cari Kasir
    const kasir = db_users.find(u => u.id_user === tx.id_user);
    document.getElementById('rec-cashier').innerText = kasir ? kasir.nama_lengkap : "Kasir";

    // Item List
    const itemsContainer = document.getElementById('rec-items-list');
    itemsContainer.innerHTML = '';
    
    details.forEach(item => {
      itemsContainer.innerHTML += `
        <div>
          <div class="flex justify-between font-bold">
            <span class="truncate pr-2">${item.nama_produk}</span>
            <span>${formatIDR(item.subtotal)}</span>
          </div>
          <div class="text-[9px] text-slate-500">
            ${item.qty} x ${formatIDR(item.harga_jual_saat_ini)}
          </div>
        </div>
      `;
    });

    document.getElementById('rec-subtotal').innerText = formatIDR(tx.total_jual);
    document.getElementById('rec-discount').innerText = formatIDR(tx.diskon);
    document.getElementById('rec-grand-total').innerText = formatIDR(tx.total_akhir);
    document.getElementById('rec-cash').innerText = formatIDR(tx.bayar);
    document.getElementById('rec-change').innerText = formatIDR(tx.kembali);

    document.getElementById('print-receipt-modal').classList.remove('hidden');
  }

  function executeBrowserPrint() {
    window.print();
  }

  function closeReceiptModal() {
    document.getElementById('print-receipt-modal').classList.add('hidden');
  }

  /******************************************************************
   * VIEW: MANAJEMEN PRODUK (CRUD)
   ******************************************************************/
