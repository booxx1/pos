  function openProductModal(prod = null) {
    const modal = document.getElementById('product-modal');
    const title = document.getElementById('product-modal-title');
    const form = document.getElementById('product-form');

    form.reset();

    if (prod) {
      title.innerText = "Edit Informasi Produk";
      document.getElementById('p-id').value = prod.id_produk;
      document.getElementById('p-barcode').value = prod.barcode;
      document.getElementById('p-name').value = prod.nama_produk;
      document.getElementById('p-category').value = prod.kategori;
      document.getElementById('p-unit').value = prod.satuan;
      document.getElementById('p-cost').value = prod.harga_beli;
      document.getElementById('p-price').value = prod.harga_jual;
      document.getElementById('p-stock').value = prod.stok;
      document.getElementById('p-stock').disabled = true; // Stok tidak boleh diedit bebas di edit, harus via Quick Restock
    } else {
      title.innerText = "Tambah Produk Baru";
      document.getElementById('p-id').value = '';
      document.getElementById('p-stock').disabled = false;
    }

    modal.classList.remove('hidden');
  }

  function closeProductModal() {
    document.getElementById('product-modal').classList.add('hidden');
  }

  function editProduct(id) {
    const prod = db_products.find(p => p.id_produk === id);
    if (prod) openProductModal(prod);
  }

  function quickRestock(id) {
    const prod = db_products.find(p => p.id_produk === id);
    if (!prod) return;

    const tambahan = prompt(`Masukkan jumlah stok tambahan untuk ${prod.nama_produk}:`, "10");
    if (tambahan === null) return;

    const qty = parseInt(tambahan);
    if (isNaN(qty) || qty <= 0) {
      showToast("Jumlah stok tambahan harus angka positif!", "error");
      return;
    }

    prod.stok += qty;

    if (IS_PREVIEW) {
      showToast("Berhasil menambah stok produk!");
      renderProductTable();
    } else {
      saveProductToCloud(prod, "Stok berhasil diperbarui.");
    }
  }

  function saveProductSubmit(e) {
    e.preventDefault();
    const id = document.getElementById('p-id').value;
    
    const prodData = {
      id_produk: id || "P" + (db_products.length + 1001),
      barcode: document.getElementById('p-barcode').value.trim(),
      nama_produk: document.getElementById('p-name').value.trim(),
      kategori: document.getElementById('p-category').value.trim(),
      satuan: document.getElementById('p-unit').value.trim(),
      harga_beli: parseInt(document.getElementById('p-cost').value),
      harga_jual: parseInt(document.getElementById('p-price').value),
      stok: parseInt(document.getElementById('p-stock').value)
    };

    if (IS_PREVIEW) {
      if (id) {
        // Edit mode
        const index = db_products.findIndex(p => p.id_produk === id);
        if (index !== -1) db_products[index] = prodData;
        showToast("Produk berhasil diperbarui!");
      } else {
        // Add mode
        db_products.push(prodData);
        showToast("Produk baru berhasil ditambahkan!");
      }
      closeProductModal();
      fetchAppData();
    } else {
      saveProductToCloud(prodData, "Data produk disimpan ke Cloud.");
    }
  }

  function saveProductToCloud(prod, successMsg) {
    showToast("Menyimpan ke Google Sheets...", "success");
    google.script.run
      .withSuccessHandler((res) => {
        if (res.success) {
          showToast(successMsg);
          closeProductModal();
          fetchAppData();
        } else {
          showToast("Gagal menyimpan produk: " + res.message, "error");
        }
      })
      .withFailureHandler((err) => {
        showToast("Error server: " + err.message, "error");
      })
      .saveProduct(prod);
  }

  function deleteProduct(id) {
    if (!confirm("Apakah Anda yakin ingin menghapus produk ini? Tindakan ini tidak bisa dibatalkan.")) return;

    if (IS_PREVIEW) {
      db_products = db_products.filter(p => p.id_produk !== id);
      showToast("Produk berhasil dihapus.");
      fetchAppData();
    } else {
      showToast("Menghapus produk dari database...", "success");
      google.script.run
        .withSuccessHandler((res) => {
          if (res.success) {
            showToast("Produk berhasil dihapus!");
            fetchAppData();
          } else {
            showToast("Gagal menghapus produk: " + res.message, "error");
          }
        })
        .withFailureHandler((err) => {
          showToast("Error server: " + err.message, "error");
        })
        .deleteProduct(id);
    }
  }

  /******************************************************************
   * VIEW: RIWAYAT TRANSAKSI (PRINT ULANG / CETAK)
   ******************************************************************/
  function renderHistoryTable() {
    const keyword = document.getElementById('history-search').value.toLowerCase();
    const dateVal = document.getElementById('history-date-filter').value;
    const body = document.getElementById('history-table-body');
    const empty = document.getElementById('history-empty');

    body.innerHTML = '';

    // Filter transaksi
    const filtered = db_transactions.filter(tx => {
      const kasir = db_users.find(u => u.id_user === tx.id_user);
      const kasirName = kasir ? kasir.nama_lengkap.toLowerCase() : '';
      const matchSearch = tx.no_invoice.toLowerCase().includes(keyword) || kasirName.includes(keyword);
      const matchDate = dateVal === "" || tx.tanggal === dateVal;
      return matchSearch && matchDate;
    });

    // Urutkan dari transaksi terbaru
    filtered.sort((a,b) => b.no_invoice.localeCompare(a.no_invoice));

    if (filtered.length === 0) {
      empty.classList.remove('hidden');
    } else {
      empty.classList.add('hidden');
      filtered.forEach(tx => {
        const kasir = db_users.find(u => u.id_user === tx.id_user);
        body.innerHTML += `
          <tr class="hover:bg-slate-50/50 transition">
            <td class="py-3.5 px-6 font-bold text-slate-800 font-mono">${tx.no_invoice}</td>
            <td class="py-3.5 px-6">
              <span class="block font-semibold text-slate-800">${tx.tanggal}</span>
              <span class="text-xs text-slate-400 font-mono">${tx.waktu}</span>
            </td>
            <td class="py-3.5 px-6 font-semibold">${kasir ? kasir.nama_lengkap : "Kasir"}</td>
            <td class="py-3.5 px-6 text-right font-mono text-rose-500">${formatIDR(tx.diskon)}</td>
            <td class="py-3.5 px-6 text-right font-mono text-indigo-600 font-bold">${formatIDR(tx.total_akhir)}</td>
            <td class="py-3.5 px-6 text-center">
              <button onclick="reprintInvoice('${tx.no_invoice}')" class="px-3 py-1.5 bg-slate-100 hover:bg-indigo-50 hover:text-indigo-600 rounded-lg text-xs font-semibold flex items-center justify-center space-x-1 mx-auto transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
                </svg>
                <span>Cetak Nota</span>
              </button>
            </td>
          </tr>
        `;
      });
    }
  }

  function reprintInvoice(invoiceNum) {
    const tx = db_transactions.find(t => t.no_invoice === invoiceNum);
    const details = db_transaction_details.filter(d => d.no_invoice === invoiceNum);
    if (tx && details.length > 0) {
      showReceipt(tx, details);
    } else {
      showToast("Detail transaksi tidak ditemukan!", "error");
    }
  }

  /******************************************************************
   * VIEW: LAPORAN PENJUALAN (GRAFIK & RINGKASAN)
   ******************************************************************/
  function renderReports() {
    // 1. Menghitung Widget Stats
    const totalOmzet = db_transactions.reduce((acc, t) => acc + t.total_akhir, 0);
    
    // Perhitungan Profit bersih = total_akhir - total_beli (HPP)
    const totalProfit = db_transactions.reduce((acc, t) => acc + (t.total_akhir - t.total_beli), 0);
    const lowStockItems = db_products.filter(p => p.stok <= 5).length;

    document.getElementById('stat-omzet').innerText = formatIDR(totalOmzet);
    document.getElementById('stat-profit').innerText = formatIDR(totalProfit);
    document.getElementById('stat-count').innerText = db_transactions.length + " Kali";
    document.getElementById('stat-low-stock').innerText = lowStockItems + " Item";

    // 2. Grafik Tren Penjualan
    // Menghitung omzet per tanggal
    const dates = [...new Set(db_transactions.map(t => t.tanggal))].sort();
    const omzets = dates.map(d => {
      return db_transactions.filter(t => t.tanggal === d).reduce((acc, t) => acc + t.total_akhir, 0);
    });

    const ctx = document.getElementById('salesTrendChart').getContext('2d');
    
    if (salesChart) salesChart.destroy(); // Hancurkan chart lama jika ada

    salesChart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: dates,
        datasets: [{
          label: 'Omzet Harian (Rp)',
          data: omzets,
          borderColor: 'rgb(79, 70, 229)',
          backgroundColor: 'rgba(79, 70, 229, 0.05)',
          tension: 0.3,
          fill: true,
          borderWidth: 3,
          pointBackgroundColor: 'rgb(79, 70, 229)',
          pointHoverRadius: 7
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              callback: function(value) { return 'Rp ' + value.toLocaleString('id-ID'); }
            }
          }
        }
      }
    });

    // 3. Produk Terlaris
    const itemSales = {};
    db_transaction_details.forEach(d => {
      itemSales[d.nama_produk] = (itemSales[d.nama_produk] || 0) + d.qty;
    });

    const topSelling = Object.keys(itemSales).map(key => ({
      name: key,
      qty: itemSales[key]
    })).sort((a,b) => b.qty - a.qty).slice(0, 5);

    const listContainer = document.getElementById('top-selling-list');
    listContainer.innerHTML = '';
    
    if (topSelling.length === 0) {
      listContainer.innerHTML = `<p class="text-xs text-slate-400">Belum ada transaksi.</p>`;
    } else {
      topSelling.forEach((item, index) => {
        listContainer.innerHTML += `
          <div class="flex items-center justify-between border-b border-slate-50 pb-2">
            <div class="flex items-center space-x-2">
              <span class="w-5 h-5 flex items-center justify-center bg-indigo-50 text-indigo-600 font-bold text-xs rounded-full">${index + 1}</span>
              <span class="text-sm text-slate-700 font-semibold truncate max-w-[180px]">${item.name}</span>
            </div>
            <span class="text-xs font-bold text-slate-500">${item.qty} Terjual</span>
          </div>
        `;
      });
    }
  }

  /******************************************************************
   * VIEW: KELOLA KASIR / PENGGUNA
   ******************************************************************/
