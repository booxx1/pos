  function handleLogin(e) {
    e.preventDefault();
    const userIn = document.getElementById('username').value.trim();
    const passIn = document.getElementById('password').value;
    const isPreviewChk = document.getElementById('chk-preview-mode').checked;
    const previewPass = document.getElementById('preview-password').value;
    const loginAlert = document.getElementById('login-alert');

    loginAlert.classList.add('hidden');

    // Cek bypass preview
    if (isPreviewChk) {
      if (previewPass === 'visualsukses') {
        // Melakukan login bypass ke role admin simulasi
        loginSuccess({ id_user: "U001", username: "admin", nama_lengkap: "Visual Sukses Admin", role: "Admin", status: "Aktif" });
        return;
      } else {
        loginAlert.innerText = "Password bypass preview salah!";
        loginAlert.classList.remove('hidden');
        return;
      }
    }

    if (IS_PREVIEW) {
      // Autentikasi lokal
      const foundUser = db_users.find(u => u.username === userIn && u.password === passIn && u.status === "Aktif");
      if (foundUser) {
        loginSuccess(foundUser);
      } else {
        loginAlert.innerText = "Username/Password salah atau akun dinonaktifkan.";
        loginAlert.classList.remove('hidden');
      }
    } else {
      // Autentikasi real cloud GAS
      document.getElementById('btn-login').disabled = true;
      document.getElementById('btn-login').innerHTML = '<span>Memverifikasi...</span>';
      
      google.script.run
        .withSuccessHandler((res) => {
          document.getElementById('btn-login').disabled = false;
          document.getElementById('btn-login').innerHTML = '<span>Masuk Aplikasi</span>';
          if (res.success) {
            loginSuccess(res.user);
          } else {
            loginAlert.innerText = res.message;
            loginAlert.classList.remove('hidden');
          }
        })
        .withFailureHandler((err) => {
          document.getElementById('btn-login').disabled = false;
          document.getElementById('btn-login').innerHTML = '<span>Masuk Aplikasi</span>';
          loginAlert.innerText = "Error server: " + err.message;
          loginAlert.classList.remove('hidden');
        })
        .loginUser(userIn, passIn);
    }
  }

