  function openUserModal(u = null) {
    const modal = document.getElementById('user-modal');
    const title = document.getElementById('user-modal-title');
    const form = document.getElementById('user-form');

    form.reset();

    if (u) {
      title.innerText = "Edit Informasi Kasir";
      document.getElementById('u-id').value = u.id_user;
      document.getElementById('u-fullname').value = u.nama_lengkap;
      document.getElementById('u-username').value = u.username;
      document.getElementById('u-password').value = u.password;
      document.getElementById('u-role').value = u.role;
      document.getElementById('u-status').value = u.status;
    } else {
      title.innerText = "Tambah Akun Kasir Baru";
      document.getElementById('u-id').value = '';
    }

    modal.classList.remove('hidden');
  }

  function closeUserModal() {
    document.getElementById('user-modal').classList.add('hidden');
  }

  function editUser(id) {
    const u = db_users.find(usr => usr.id_user === id);
    if (u) openUserModal(u);
  }

  function saveUserSubmit(e) {
    e.preventDefault();
    const id = document.getElementById('u-id').value;

    const userData = {
      id_user: id || "U" + (db_users.length + 101).toString(),
      nama_lengkap: document.getElementById('u-fullname').value.trim(),
      username: document.getElementById('u-username').value.trim(),
      password: document.getElementById('u-password').value,
      role: document.getElementById('u-role').value,
      status: document.getElementById('u-status').value
    };

    if (IS_PREVIEW) {
      if (id) {
        const index = db_users.findIndex(usr => usr.id_user === id);
        if (index !== -1) db_users[index] = userData;
        showToast("Akun kasir berhasil diperbarui.");
      } else {
        db_users.push(userData);
        showToast("Akun kasir baru berhasil dibuat.");
      }
      closeUserModal();
      fetchAppData();
    } else {
      showToast("Menyimpan akun kasir ke database...", "success");
      google.script.run
        .withSuccessHandler((res) => {
          if (res.success) {
            showToast("Akun kasir disimpan.");
            closeUserModal();
            fetchAppData();
          } else {
            showToast("Gagal menyimpan akun: " + res.message, "error");
          }
        })
        .withFailureHandler((err) => {
          showToast("Error server: " + err.message, "error");
        })
        .saveUser(userData);
    }
  }

  /******************************************************************
   * VIEW: PENGATURAN TOKO (SAVE)
   ******************************************************************/
  function saveStoreSettings(e) {
    e.preventDefault();
    
    const settingsData = {
      nama_toko: document.getElementById('setting-shop-name').value.trim(),
      alamat_toko: document.getElementById('setting-shop-address').value.trim(),
      telepon_toko: document.getElementById('setting-shop-phone').value.trim(),
      footer_struk: document.getElementById('setting-shop-footer').value.trim()
    };

    if (IS_PREVIEW) {
      db_settings = settingsData;
      applySettings(db_settings);
      showToast("Profil toko berhasil disimpan!");
    } else {
      showToast("Menyimpan konfigurasi toko...", "success");
      google.script.run
        .withSuccessHandler((res) => {
          if (res.success) {
            showToast("Profil toko berhasil diperbarui!");
            fetchAppData();
          } else {
            showToast("Gagal menyimpan konfigurasi: " + res.message, "error");
          }
        })
        .withFailureHandler((err) => {
          showToast("Error server: " + err.message, "error");
        })
        .saveSettings(settingsData);
    }
  }
